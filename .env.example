# Environment Variables for Smart Meeting Orchestrator

# Surge SMS API Configuration
SURGE_SMS_API_KEY=sk_live_your_api_key_here
SURGE_ACCOUNT_ID=acct_your_account_id_here

# Database Configuration (Railway will provide this)
DATABASE_URL=postgresql://username:password@host:port/database

# Application Configuration
ENVIRONMENT=production
PORT=8000

# Google API Configuration (for future real integration)
GOOGLE_CALENDAR_CREDENTIALS_PATH=/app/credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=/app/token.json

# Railway Configuration
WEBHOOK_URL=https://your-railway-app.up.railway.app/webhook/sms
